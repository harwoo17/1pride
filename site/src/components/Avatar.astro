---
// Tier avatar — flat illustrated character art per tier (drop-in PNGs at
// /public/avatars/<slug>.png). Same API as before (tier 1..7, size,
// locked) so every caller — DepthChart, DepthChartStrip, FieldJourney,
// the lesson header — just works. `locked` desaturates for un-earned
// tiers.
import { TIERS } from '~/data/tiers';

interface Props {
	tier: number;        // 1..7
	size?: number;
	locked?: boolean;
}
const { tier, size = 132, locked = false } = Astro.props;
const t = TIERS[tier - 1];
---

<span class={`avatar ${locked ? 'is-locked' : ''}`} role="img" aria-label={`${t.label} avatar`}>
	<img
		src={`/avatars/${t.slug}.png`}
		width={size}
		height={size}
		alt={`${t.label}`}
		loading="lazy"
		decoding="async"
	/>
</span>

<style>
	.avatar {
		display: inline-flex;
		line-height: 0;
	}
	.avatar img {
		display: block;
		object-fit: contain;
	}
	.avatar.is-locked img {
		filter: grayscale(0.92) brightness(0.95);
		opacity: 0.4;
	}
</style>
