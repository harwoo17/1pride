---
// 3D depth-chart avatar bust (design brief §8 + avatars-3d-spec.md).
// Late-90s pre-rendered CGI look: chrome sphere head, Honolulu-blue
// uniform shoulders with a green seam, silver pedestal, visor band, one
// key light upper-left + lower-left rim, soft contact shadow. One prop
// per tier; Owner is the only gold. `locked` renders a desaturated
// silhouette for tiers not yet unlocked.
//
// Materials are the spec's exact gradients, EXCEPT the uniform shadow is
// capped at honolulu-700 (#00659c) instead of #005075 — no navy.
import { TIERS } from '~/data/tiers';

interface Props {
	tier: number;        // 1..7
	size?: number;
	locked?: boolean;
}
const { tier, size = 132, locked = false } = Astro.props;
const t = TIERS[tier - 1];
const gold = t.accent === 'gold';
const uid = `av${tier}`;            // unique gradient ids per instance
const accentGrad = gold ? `${uid}-gold` : `${uid}-green`;
const badgeFill = gold ? `url(#${uid}-gold)` : `url(#${uid}-green)`;
const badgeText = gold ? '#3a2c06' : '#06351c';
---

<span class={`avatar ${locked ? 'is-locked' : ''}`} role="img" aria-label={`${t.label} avatar`}>
	<svg width={size} height={size} viewBox="0 0 200 210" xmlns="http://www.w3.org/2000/svg">
		<defs>
			<radialGradient id={`${uid}-chrome`} cx="38%" cy="30%" r="78%">
				<stop offset="0%" stop-color="#ffffff" />
				<stop offset="35%" stop-color="#dfe4e7" />
				<stop offset="72%" stop-color="#b0b7bc" />
				<stop offset="100%" stop-color="#71777c" />
			</radialGradient>
			<linearGradient id={`${uid}-blue`} x1="0" y1="0" x2="0" y2="1">
				<stop offset="0%" stop-color="#56b5e8" />
				<stop offset="52%" stop-color="#0076b6" />
				<stop offset="100%" stop-color="#00659c" />
			</linearGradient>
			<radialGradient id={`${uid}-green`} cx="38%" cy="32%" r="75%">
				<stop offset="0%" stop-color="#9af3bb" />
				<stop offset="55%" stop-color="#34e27a" />
				<stop offset="100%" stop-color="#16934e" />
			</radialGradient>
			<radialGradient id={`${uid}-gold`} cx="38%" cy="32%" r="75%">
				<stop offset="0%" stop-color="#fff6cf" />
				<stop offset="55%" stop-color="#e9c95a" />
				<stop offset="100%" stop-color="#9c7a1e" />
			</radialGradient>
			<linearGradient id={`${uid}-silver`} x1="0" y1="0" x2="0" y2="1">
				<stop offset="0%" stop-color="#eef1f3" />
				<stop offset="55%" stop-color="#b0b7bc" />
				<stop offset="100%" stop-color="#6f767b" />
			</linearGradient>
			<linearGradient id={`${uid}-visor`} x1="0" y1="0" x2="1" y2="0">
				<stop offset="0%" stop-color="#2c2e30" />
				<stop offset="50%" stop-color="#1b1c1d" />
				<stop offset="100%" stop-color="#3a3d40" />
			</linearGradient>
		</defs>

		<!-- soft contact shadow -->
		<ellipse cx="100" cy="196" rx="58" ry="9" fill="rgba(0,0,0,0.28)" />

		<!-- pedestal -->
		<path d="M58 196 Q58 176 100 176 Q142 176 142 196 Z" fill={`url(#${uid}-silver)`} />
		<ellipse cx="100" cy="176" rx="42" ry="7" fill="#d7dce0" />
		<!-- pedestal accent ring -->
		<ellipse cx="100" cy="176" rx="42" ry="7" fill="none" stroke={badgeFill} stroke-width="2" opacity="0.9" />

		<!-- shoulders / uniform -->
		<path d="M44 178 Q50 120 100 120 Q150 120 156 178 Q130 168 100 168 Q70 168 44 178 Z" fill={`url(#${uid}-blue)`} />
		<!-- green/gold seam -->
		<path d="M100 124 Q100 150 100 168" stroke={badgeFill} stroke-width="3" fill="none" opacity="0.95" />
		<path d="M70 132 Q60 152 56 172" stroke={badgeFill} stroke-width="2" fill="none" opacity="0.55" />
		<path d="M130 132 Q140 152 144 172" stroke={badgeFill} stroke-width="2" fill="none" opacity="0.55" />

		<!-- collar -->
		<path d="M82 122 Q100 134 118 122 L118 128 Q100 140 82 128 Z" fill="#eef1f3" opacity="0.9" />

		<!-- chrome head -->
		<circle cx="100" cy="84" r="46" fill={`url(#${uid}-chrome)`} />
		<!-- rim light lower-left -->
		<path d="M62 104 A46 46 0 0 1 70 56" fill="none" stroke={gold ? '#fff6cf' : '#9af3bb'} stroke-width="2.4" opacity="0.7" stroke-linecap="round" />
		<!-- specular highlight upper-left -->
		<ellipse cx="84" cy="64" rx="13" ry="9" fill="#ffffff" opacity="0.55" />

		<!-- visor band — glossy tinted sport visor (no facial features) -->
		<path d="M57 83 Q100 96 143 83 L143 97 Q100 110 57 97 Z" fill={`url(#${uid}-visor)`} />
		<!-- specular streak so it reads as glass, not a flat bar -->
		<path d="M64 87 Q100 96 136 87" stroke="#ffffff" stroke-width="2.4" fill="none" opacity="0.38" stroke-linecap="round" />
		<!-- accent underline -->
		<path d="M61 93 Q100 103 139 93" stroke={badgeFill} stroke-width="1.6" fill="none" opacity="0.9" />

		{/* ── per-tier prop ────────────────────────────────────────── */}
		{tier === 1 && (
			<g>{/* headset + clipboard */}
				<path d="M58 84 A44 44 0 0 1 142 84" fill="none" stroke="#1b1c1d" stroke-width="4" opacity="0.9" />
				<rect x="50" y="82" width="10" height="16" rx="3" fill="#1b1c1d" />
				<path d="M56 96 Q48 110 70 116" stroke="#3a3d40" stroke-width="3" fill="none" />
				<rect x="120" y="150" width="34" height="26" rx="2" fill="#eef1f3" stroke="#6f767b" stroke-width="1.5" transform="rotate(8 137 163)" />
				<line x1="126" y1="158" x2="148" y2="160" stroke={badgeFill} stroke-width="1.6" transform="rotate(8 137 163)" />
			</g>
		)}
		{tier === 2 && (
			<g>{/* stopwatch — Quality Control times the reps */}
				<circle cx="100" cy="151" r="16" fill="#eef1f3" stroke="#16934e" stroke-width="2.6" />
				<circle cx="100" cy="151" r="16" fill="none" stroke="#6f767b" stroke-width="0.8" opacity="0.5" />
				<rect x="95" y="129" width="10" height="7" rx="2" fill="#6f767b" />
				<line x1="100" y1="129" x2="100" y2="125" stroke="#6f767b" stroke-width="2.6" stroke-linecap="round" />
				<line x1="113" y1="138" x2="116" y2="135" stroke="#6f767b" stroke-width="2.2" stroke-linecap="round" />
				{/* hands */}
				<line x1="100" y1="151" x2="100" y2="141" stroke="#0076b6" stroke-width="2.4" stroke-linecap="round" />
				<line x1="100" y1="151" x2="108" y2="154" stroke="#16934e" stroke-width="2.2" stroke-linecap="round" />
				<circle cx="100" cy="151" r="2.2" fill="#0b0b0c" />
				{/* tick marks */}
				<circle cx="100" cy="139" r="1" fill="#16934e" />
				<circle cx="112" cy="151" r="1" fill="#6f767b" />
				<circle cx="100" cy="163" r="1" fill="#6f767b" />
				<circle cx="88" cy="151" r="1" fill="#6f767b" />
			</g>
		)}
		{tier === 3 && (
			<g>{/* whistle on a lanyard — bigger, with bore + mouthpiece */}
				<path d="M82 120 L96 150 M118 120 L104 150" stroke="#eef1f3" stroke-width="2.5" fill="none" />
				<path d="M88 149 h20 a8 8 0 0 1 8 8 a10 10 0 0 1 -10 10 h-16 a5 5 0 0 1 -5 -5 v-8 a5 5 0 0 1 0 -5 z" fill={badgeFill} stroke="#16934e" stroke-width="1.5" />
				<rect x="106" y="151" width="14" height="6" rx="3" fill={badgeFill} stroke="#16934e" stroke-width="1.2" />
				<circle cx="99" cy="160" r="3.6" fill="#06351c" opacity="0.55" />
			</g>
		)}
		{tier === 4 && (
			<g>{/* laminated call-sheet held up — reads as a play card (X's & O's) */}
				<rect x="73" y="137" width="54" height="40" rx="3" fill="#eef1f3" stroke="#6f767b" stroke-width="1.5" transform="rotate(-4 100 157)" />
				<g transform="rotate(-4 100 157)">
					<text x="80" y="151" font-family="monospace" font-size="8" font-weight="700" fill="#0076b6">X O X</text>
					<path d="M82 155 q9 5 18 0" stroke="#16934e" stroke-width="1.3" fill="none" stroke-dasharray="1 2" />
					<line x1="80" y1="162" x2="120" y2="162" stroke="#0076b6" stroke-width="1.3" />
					<line x1="80" y1="168" x2="112" y2="168" stroke="#6f767b" stroke-width="1.3" />
				</g>
			</g>
		)}
		{tier === 5 && (
			<g>{/* visor cap brim + headset */}
				<path d="M54 70 Q100 44 146 70 L150 78 Q100 60 50 78 Z" fill={`url(#${uid}-blue)`} stroke="#00659c" stroke-width="1" />
				<path d="M50 78 Q40 80 36 86" fill="none" stroke="#1b1c1d" stroke-width="3" />
				<rect x="48" y="84" width="9" height="15" rx="3" fill="#1b1c1d" />
				<path d="M52 99 Q46 110 66 114" stroke="#3a3d40" stroke-width="2.5" fill="none" />
			</g>
		)}
		{tier === 6 && (
			<g>{/* suit lapel + tie + roster tablet */}
				<path d="M88 122 L100 150 L112 122" fill="none" stroke="#1b1c1d" stroke-width="2" opacity="0.6" />
				<path d="M97 130 L100 150 L103 130 Z" fill={badgeFill} />
				<rect x="116" y="146" width="30" height="30" rx="3" fill="#1b1c1d" transform="rotate(6 131 161)" />
				<rect x="120" y="150" width="22" height="22" rx="1" fill={badgeFill} opacity="0.85" transform="rotate(6 131 161)" />
			</g>
		)}
		{tier === 7 && (
			<g>{/* silver blazer + gold ring/crest */}
				<path d="M82 122 L100 152 L118 122" fill="none" stroke="#eef1f3" stroke-width="3" />
				<path d="M86 124 L100 150 L100 168 Z" fill="#d7dce0" opacity="0.6" />
				<path d="M114 124 L100 150 L100 168 Z" fill="#b0b7bc" opacity="0.6" />
				<!-- crest -->
				<path d="M100 132 l8 4 v8 q0 8 -8 11 q-8 -3 -8 -11 v-8 z" fill={`url(#${uid}-gold)`} stroke="#9c7a1e" stroke-width="1" />
				<circle cx="100" cy="143" r="3.4" fill="#fff6cf" />
			</g>
		)}

		<!-- tier badge -->
		<g transform="translate(100,196)">
			<rect x="-15" y="-9" width="30" height="18" rx="9" fill={badgeFill} stroke={gold ? '#9c7a1e' : '#16934e'} stroke-width="1" />
			<text x="0" y="4" text-anchor="middle" font-family="monospace" font-size="11" font-weight="700" fill={badgeText}>{t.n}</text>
		</g>

		{locked && <rect x="0" y="0" width="200" height="210" fill="#0076b6" opacity="0.0" />}
	</svg>
</span>

<style>
	.avatar { display: inline-flex; line-height: 0; }
	.avatar.is-locked svg {
		filter: grayscale(0.85) brightness(0.9);
		opacity: 0.42;
	}
</style>
