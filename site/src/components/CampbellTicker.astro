---
// Org-wide voices ticker — quotes and composite voices from across the
// Lions org, head coach down to analytics. Mirrors the QuoteTicker on
// the L5 app for visual continuity. Real attributable quotes carry the
// name; the rest are role-based composite voices.

const ORG_VOICES: { role: string; text: string }[] = [
	{ role: 'HC · Dan Campbell', text: 'Bite a kneecap off.' },
	{ role: 'GM · Brad Holmes', text: 'I love these dudes.' },
	{ role: 'HC · Dan Campbell', text: 'Punch you in the mouth.' },
	{ role: 'Ownership', text: 'Win in Detroit. Win for Detroit.' },
	{ role: "HC · Dan Campbell", text: "We don't blink." },
	{ role: 'GM · Brad Holmes', text: "We're going to swing big." },
	{ role: 'HC · Dan Campbell', text: 'These dudes.' },
	{ role: 'OC · Play caller', text: "Aggressive isn't reckless." },
	{ role: 'HC · Dan Campbell', text: 'Knock you down. Get up. Knock you down again.' },
	{ role: 'DC · Defense', text: 'Set the standard.' },
	{ role: 'HC · Dan Campbell', text: 'Hard. Tough. Smart. Disciplined.' },
	{ role: 'Position coach', text: 'Brick by brick.' },
	{ role: 'HC · Dan Campbell', text: "We're gonna kick you in the teeth." },
	{ role: 'Scouting', text: 'Eyes on every snap.' },
	{ role: 'HC · Dan Campbell', text: 'Earn the right.' },
	{ role: 'Analytics', text: 'Trust the chart. Trust the EPA.' },
	{ role: 'Locker room', text: 'Forward. Always forward.' },
	{ role: 'Offensive line', text: 'Move the rock.' },
];

const entries = [...ORG_VOICES, ...ORG_VOICES];
---

<div class="campbell-ticker" role="marquee" aria-label="Voices from across the Lions org">
	<div class="campbell-track">
		{
			entries.map((v, i) => (
				<span class="campbell-quote">
					<span class="campbell-quote-num">
						{String((i % ORG_VOICES.length) + 1).padStart(2, '0')}
					</span>
					<span class="campbell-quote-role">{v.role}</span>
					<span class="campbell-quote-text">&ldquo;{v.text}&rdquo;</span>
				</span>
			))
		}
	</div>
</div>

<style>
	.campbell-ticker {
		position: relative;
		overflow: hidden;
		background: var(--lions-blue);
		color: #ffffff;
		border-top: 2px solid var(--lions-blue);
		border-bottom: 2px solid var(--lions-blue);
		margin: 2rem 0 2.5rem;
	}
	.campbell-track {
		display: flex;
		width: max-content;
		gap: 3rem;
		padding: 0.85rem 0;
		white-space: nowrap;
		animation: campbell-scroll 60s linear infinite;
		will-change: transform;
	}
	.campbell-track:hover {
		animation-play-state: paused;
	}
	@keyframes campbell-scroll {
		0%   { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}
	@media (prefers-reduced-motion: reduce) {
		.campbell-track { animation: none; }
	}
	.campbell-quote {
		display: inline-flex;
		align-items: baseline;
		gap: 0.65rem;
		font-family: var(--font-display);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-size: 1rem;
	}
	.campbell-quote-num {
		font-family: var(--sl-font-mono);
		font-size: 0.7rem;
		opacity: 0.55;
		font-weight: 500;
	}
	.campbell-quote-text {
		font-size: 1rem;
	}
	.campbell-quote-role {
		display: inline-block;
		background: #ffffff;
		color: var(--lions-blue);
		padding: 0.1rem 0.45rem;
		font-size: 0.62rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		border-radius: 2px;
	}
</style>
