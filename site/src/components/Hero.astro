---
// src/components/Hero.astro
//
// The opening. Honolulu blue + thin retro-green grid, solid/outline headline,
// the keyed lion (loops silent, ROARS ON CLICK), and a 360° wireframe football.
//
// Assets it expects (see brief §3 / §11):
//   /public/media/lion-roar.webm   (chroma-green keyed out via the ffmpeg step)
//   /public/media/lion-poster.png  (a single still frame, for reduced-motion / slow loads)
//   /public/sfx/roar.mp3
---

<section class="hero">
  <div class="grid-bg" aria-hidden="true"></div>

  <div class="hero-inner">
    <div class="copy">
      <p class="annot">FIG. 01 — DEPTH CHART</p>
      <h1>
        <span class="solid">RUN YOUR REPS.</span>
        <span class="outline">CLIMB THE DEPTH CHART.</span>
      </h1>
      <p class="mission">Training the next generation of NFL analysts.</p>
      <a class="cta" href="/lessons/01-reading-the-run-game">Start Training Camp →</a>
      <div class="dimline" aria-hidden="true"><span>10 YDS</span></div>
    </div>

    <div class="stage">
      <button class="lion" id="lionRoar" type="button" aria-label="Hear the roar">
        <video id="lionVideo" autoplay muted loop playsinline
               poster="/media/lion-poster.png">
          <source src="/media/lion-roar.webm" type="video/webm" />
        </video>
        <span class="roar-hint">▶ tap to roar</span>
      </button>

      <div class="football" aria-hidden="true">
        <svg viewBox="-120 -70 240 140" xmlns="http://www.w3.org/2000/svg">
          <ellipse rx="105" ry="56" fill="none" stroke="#B0B7BC" stroke-width="3" />
          <ellipse rx="70" ry="56" fill="none" stroke="#34E27A" stroke-width="1.5" opacity="0.7" />
          <ellipse rx="32" ry="56" fill="none" stroke="#34E27A" stroke-width="1.5" opacity="0.5" />
          <line x1="-46" y1="0" x2="46" y2="0" stroke="#fff" stroke-width="3" />
          <g stroke="#fff" stroke-width="3">
            <line x1="-34" y1="-9" x2="-34" y2="9" />
            <line x1="-17" y1="-9" x2="-17" y2="9" />
            <line x1="0" y1="-9" x2="0" y2="9" />
            <line x1="17" y1="-9" x2="17" y2="9" />
            <line x1="34" y1="-9" x2="34" y2="9" />
          </g>
        </svg>
      </div>
    </div>
  </div>

  <audio id="roarAudio" src="/sfx/roar.mp3" preload="auto"></audio>
</section>

<style>
  .hero {
    --honolulu: #0076b6;
    --silver: #b0b7bc;
    --retro-green: #34e27a;
    position: relative;
    overflow: hidden;
    background: var(--honolulu);
    color: #fff;
    min-height: 88vh;
    display: flex;
    align-items: center;
  }
  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--retro-green) 1px, transparent 1px),
      linear-gradient(90deg, var(--retro-green) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.16; /* thin green line — the key retro-future cue */
    -webkit-mask-image: radial-gradient(ellipse 120% 100% at 50% 40%, #000 55%, transparent 100%);
            mask-image: radial-gradient(ellipse 120% 100% at 50% 40%, #000 55%, transparent 100%);
  }
  /* CRT vignette + faint scanlines (brief §12) — tasteful, off when
     the visitor prefers reduced motion */
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      repeating-linear-gradient(180deg, rgba(0,0,0,0.05) 0 1px, transparent 1px 3px),
      radial-gradient(ellipse 90% 80% at 50% 42%, transparent 58%, rgba(0,0,0,0.20) 100%);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero::after { background: radial-gradient(ellipse 90% 80% at 50% 42%, transparent 60%, rgba(0,0,0,0.16) 100%); }
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 32px;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 24px;
  }
  .annot {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 3px;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 12px;
  }
  h1 {
    font-family: "Archivo Expanded", "Saira", sans-serif;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 0.95;
    font-size: clamp(44px, 8vw, 104px);
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  h1 .solid { color: #fff; }
  h1 .outline {
    color: transparent;
    -webkit-text-stroke: 2px #fff;
    text-stroke: 2px #fff;
  }
  .mission {
    font-family: "JetBrains Mono", monospace;
    font-size: clamp(13px, 1.6vw, 16px);
    color: rgba(255, 255, 255, 0.85);
    margin: 24px 0 28px;
  }
  .cta {
    display: inline-block;
    font-family: "JetBrains Mono", monospace;
    font-size: 14px;
    text-decoration: none;
    padding: 12px 22px;
    border-radius: 8px;
    background: #fff;
    color: #0b0b0c;
    border: 1px solid var(--silver);
    transition: transform 0.12s ease;
  }
  .cta:hover { transform: translateY(-2px); }
  .dimline {
    position: relative;
    margin-top: 36px;
    height: 1px;
    width: 280px;
    background: var(--retro-green);
    opacity: 0.8;
  }
  .dimline::before, .dimline::after {
    content: "";
    position: absolute;
    top: -5px;
    width: 1px;
    height: 11px;
    background: var(--retro-green);
  }
  .dimline::before { left: 0; }
  .dimline::after { right: 0; }
  .dimline span {
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--retro-green);
  }

  .stage {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
  }
  /* soft spotlight grounding the lion on the grid */
  .stage::before {
    content: "";
    position: absolute;
    width: 78%;
    height: 78%;
    top: 8%;
    left: 11%;
    background: radial-gradient(ellipse at 50% 45%, rgba(255,255,255,0.16) 0%, rgba(255,255,255,0) 62%);
    pointer-events: none;
    z-index: 0;
  }
  .lion { z-index: 1; }
  .lion {
    position: relative;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    transform-origin: center bottom;
  }
  .lion video {
    width: clamp(280px, 36vw, 460px);
    height: auto;
    display: block;
    filter: drop-shadow(0 18px 30px rgba(0, 0, 0, 0.35));
  }
  .roar-hint {
    position: absolute;
    bottom: 6px;
    left: 50%;
    transform: translateX(-50%);
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--silver);
    background: rgba(0, 0, 0, 0.35);
    padding: 3px 8px;
    border-radius: 999px;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .lion:hover .roar-hint { opacity: 0; }

  .football {
    position: absolute;
    right: -6px;
    bottom: 18px;
    width: 188px;
    perspective: 700px;
  }
  /* faint green glow disk behind the spinning ball */
  .football::before {
    content: "";
    position: absolute;
    inset: -18% -18%;
    background: radial-gradient(circle, rgba(52,226,122,0.22) 0%, rgba(52,226,122,0) 68%);
    pointer-events: none;
  }
  .football svg {
    width: 100%;
    animation: spinY 6s linear infinite;
    transform-style: preserve-3d;
  }
  @keyframes spinY {
    from { transform: rotateY(0deg); }
    to { transform: rotateY(360deg); }
  }
  @keyframes shake {
    0% { transform: scale(1) rotate(0); }
    25% { transform: scale(1.04) rotate(-1.5deg); }
    50% { transform: scale(1.02) rotate(1.5deg); }
    100% { transform: scale(1) rotate(0); }
  }
  .lion.shake { animation: shake 0.45s ease; }

  @media (max-width: 820px) {
    .hero-inner { grid-template-columns: 1fr; }
    .football { right: 10px; bottom: -10px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .football svg { animation: none; }
    .lion.shake { animation: none; }
  }
</style>

<script>
  const btn = document.getElementById("lionRoar");
  const audio = document.getElementById("roarAudio") as HTMLAudioElement | null;
  const video = document.getElementById("lionVideo") as HTMLVideoElement | null;
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Reduced motion: hold on the poster frame instead of looping.
  if (reduce && video) {
    video.removeAttribute("autoplay");
    video.pause();
  }

  btn?.addEventListener("click", () => {
    // Respect the global mute toggle (sound system sets "pride-muted").
    if (audio && localStorage.getItem("pride-muted") !== "1") {
      audio.currentTime = 0;
      audio.play().catch(() => {});
    }
    // Re-trigger the shake animation.
    btn.classList.remove("shake");
    void (btn as HTMLElement).offsetWidth;
    btn.classList.add("shake");
    // Reduced-motion: let the roar play through once, then settle.
    if (reduce && video) {
      video.currentTime = 0;
      video.play();
      window.setTimeout(() => video.pause(), 1600);
    }
  });
</script>
