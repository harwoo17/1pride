---
// Depth-chart level icons — one flat, two-tone glyph per curriculum level,
// drawn in the 1PRIDE palette (Honolulu blue primary + silver accent, white
// negative space). On-brand with the broadcast/varsity aesthetic; no gold.
//
//   L1 Analyst        — magnifying glass over a bar chart (pull the stat)
//   L2 Position coach — clipboard with an X/O play (develop the group)
//   L3 Head coach     — whistle (situational calls)
//   L4 GM             — org/depth chart (roster construction)
//   L5 Owner          — trophy (franchise strategy)
//
// Usage:  <LevelIcon level={1} />   or   <LevelIcon level={3} size={56} />

interface Props {
	level: 1 | 2 | 3 | 4 | 5;
	size?: number;
}
const { level, size = 40 } = Astro.props;
const roles = {
	1: 'Analyst',
	2: 'Position coach',
	3: 'Head coach',
	4: 'General manager',
	5: 'Owner',
} as const;
const blue = 'var(--lions-blue)';
const steel = 'var(--lions-silver-dark)';
---

<span class="level-icon" role="img" aria-label={`Level ${level} — ${roles[level]}`}>
	{level === 1 && (
		<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
			<line x1="29" y1="29" x2="41" y2="41" stroke={blue} stroke-width="5" stroke-linecap="round" />
			<circle cx="20" cy="20" r="13" fill="#fff" stroke={blue} stroke-width="3.2" />
			<rect x="13.4" y="20" width="3.6" height="7" rx="0.6" fill={steel} />
			<rect x="18.2" y="15.5" width="3.6" height="11.5" rx="0.6" fill={blue} />
			<rect x="23" y="18" width="3.6" height="9" rx="0.6" fill={steel} />
		</svg>
	)}
	{level === 2 && (
		<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
			<rect x="9" y="9" width="30" height="33" rx="3" fill="#fff" stroke={blue} stroke-width="3.2" />
			<rect x="18" y="5.5" width="12" height="7" rx="2" fill={blue} />
			<circle cx="17" cy="23" r="3.3" fill="none" stroke={steel} stroke-width="2.4" />
			<path d="M26 19.5 l5 5 M31 19.5 l-5 5" stroke={blue} stroke-width="2.6" stroke-linecap="round" />
			<path d="M17 27 q0 7 9 8.4" stroke={blue} stroke-width="2.2" stroke-linecap="round" stroke-dasharray="0.5 4" fill="none" />
			<path d="M26 35.4 l-3.6 -0.8 M26 35.4 l-0.9 -3.5" stroke={blue} stroke-width="2.2" stroke-linecap="round" />
		</svg>
	)}
	{level === 3 && (
		<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M9 12 q9 -6 16.5 1" stroke={steel} stroke-width="2.6" fill="none" stroke-linecap="round" />
			<rect x="22.2" y="11.5" width="6.5" height="5" rx="2" fill={steel} />
			<circle cx="24" cy="28.5" r="11" fill={blue} />
			<path d="M34.5 24.5 h8.5 a2.5 2.5 0 0 1 2.5 2.5 v3 a2.5 2.5 0 0 1 -2.5 2.5 h-8.5 z" fill={blue} />
			<circle cx="24" cy="23" r="2.7" fill="#fff" />
		</svg>
	)}
	{level === 4 && (
		<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
			<rect x="18" y="7" width="12" height="9" rx="2" fill={blue} />
			<path d="M24 16 v6 M11 22 H37 M11 22 v5 M24 22 v5 M37 22 v5" stroke={steel} stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
			<rect x="5.5" y="28" width="11" height="9" rx="2" fill="#fff" stroke={blue} stroke-width="2.8" />
			<rect x="18.5" y="28" width="11" height="9" rx="2" fill="#fff" stroke={blue} stroke-width="2.8" />
			<rect x="31.5" y="28" width="11" height="9" rx="2" fill="#fff" stroke={blue} stroke-width="2.8" />
		</svg>
	)}
	{level === 5 && (
		<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M15 9 H33 V14 A9 9 0 0 1 15 14 Z" fill={blue} />
			<path d="M15 10 H10 A4 4 0 0 0 10 19 H13" fill="none" stroke={steel} stroke-width="2.6" />
			<path d="M33 10 H38 A4 4 0 0 1 38 19 H35" fill="none" stroke={steel} stroke-width="2.6" />
			<rect x="22" y="22" width="4" height="6" fill={blue} />
			<path d="M17 34 q0 -6 7 -6 q7 0 7 6 Z" fill={steel} />
			<rect x="15" y="34" width="18" height="4.6" rx="1.2" fill={blue} />
			<path d="M24 8.8 L25 11.63 L27.99 11.7 L25.62 13.53 L26.47 16.4 L24 14.7 L21.53 16.4 L22.38 13.53 L20.01 11.7 L23 11.63 Z" fill="#fff" />
		</svg>
	)}
</span>
