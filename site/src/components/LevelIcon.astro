---
// Depth-chart level icons — cohesive HUD line set per design brief §6.
// 1.5px stroke, Honolulu primary + silver detail + a retro-green accent
// tick. Themes via currentColor where possible. Not flat fills, not stock.
//
//   L1 Analyst        — loupe over a play diagram (X's & O's): film study
//   L2 Position coach — whistle on a lanyard
//   L3 Head coach     — headset + visor (call it in)
//   L4 GM             — roster tree (org chart)
//   L5 Owner          — trophy (Game Day)
//
// Usage:  <LevelIcon level={1} />   or   <LevelIcon level={3} size={56} />

interface Props {
	level: 1 | 2 | 3 | 4 | 5;
	size?: number;
}
const { level, size = 40 } = Astro.props;
const roles = {
	1: 'Analyst',
	2: 'Position coach',
	3: 'Head coach',
	4: 'General manager',
	5: 'Owner',
} as const;
const blue = 'var(--honolulu, #0076b6)';
const steel = 'var(--silver, #b0b7bc)';
const green = 'var(--retro-green, #34e27a)';
const SW = 1.6;
---

<span class="level-icon" role="img" aria-label={`Tier — ${roles[level]}`}>
	{level === 1 && (
		<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
			{/* play diagram card */}
			<rect x="5" y="9" width="26" height="20" rx="2" stroke={steel} stroke-width={SW} />
			<text x="10" y="22" font-family="monospace" font-size="8" fill={blue}>X</text>
			<text x="20" y="25" font-family="monospace" font-size="8" fill={blue}>O</text>
			<path d="M13 25 q6 -4 11 -9" stroke={green} stroke-width={SW} stroke-dasharray="1 2.5" stroke-linecap="round" />
			{/* loupe */}
			<circle cx="30" cy="30" r="8.5" fill="#fff" stroke={blue} stroke-width={SW + 0.4} />
			<line x1="36" y1="36" x2="43" y2="43" stroke={blue} stroke-width={SW + 1} stroke-linecap="round" />
		</svg>
	)}
	{level === 2 && (
		<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
			{/* lanyard */}
			<path d="M16 6 L23 22 M32 6 L25 22" stroke={steel} stroke-width={SW} stroke-linecap="round" />
			{/* whistle body */}
			<path d="M14 24 h14 a6 6 0 0 1 6 6 a8 8 0 0 1 -8 8 h-9 a3 3 0 0 1 -3 -3 v-8 a3 3 0 0 1 0 -3 z" fill="#fff" stroke={blue} stroke-width={SW + 0.4} stroke-linejoin="round" />
			<circle cx="22" cy="31" r="3.4" stroke={blue} stroke-width={SW} />
			<line x1="9" y1="27" x2="14" y2="27" stroke={green} stroke-width={SW + 0.6} stroke-linecap="round" />
		</svg>
	)}
	{level === 3 && (
		<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
			{/* headset band */}
			<path d="M11 26 a13 13 0 0 1 26 0" stroke={blue} stroke-width={SW + 0.4} />
			<rect x="8" y="25" width="6" height="11" rx="2.5" fill="#fff" stroke={blue} stroke-width={SW} />
			<rect x="34" y="25" width="6" height="11" rx="2.5" fill="#fff" stroke={blue} stroke-width={SW} />
			{/* mic boom */}
			<path d="M14 33 q-4 6 6 7" stroke={steel} stroke-width={SW} stroke-linecap="round" />
			<circle cx="21" cy="40" r="2.2" fill={green} />
		</svg>
	)}
	{level === 4 && (
		<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
			{/* roster tree */}
			<rect x="18" y="6" width="12" height="8" rx="1.5" fill="#fff" stroke={blue} stroke-width={SW} />
			<path d="M24 14 v6 M10 20 H38 M10 20 v6 M24 20 v6 M38 20 v6" stroke={steel} stroke-width={SW} stroke-linecap="round" stroke-linejoin="round" />
			<rect x="5" y="26" width="10" height="8" rx="1.5" fill="#fff" stroke={blue} stroke-width={SW} />
			<rect x="19" y="26" width="10" height="8" rx="1.5" fill="#fff" stroke={blue} stroke-width={SW} />
			<rect x="33" y="26" width="10" height="8" rx="1.5" fill="#fff" stroke={blue} stroke-width={SW} />
			<circle cx="24" cy="10" r="1.6" fill={green} />
		</svg>
	)}
	{level === 5 && (
		<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
			{/* trophy */}
			<path d="M16 8 H32 V15 A8 8 0 0 1 16 15 Z" fill="#fff" stroke={blue} stroke-width={SW + 0.4} stroke-linejoin="round" />
			<path d="M16 10 H11 A4 4 0 0 0 11 18 H14" stroke={steel} stroke-width={SW} />
			<path d="M32 10 H37 A4 4 0 0 1 37 18 H34" stroke={steel} stroke-width={SW} />
			<line x1="24" y1="23" x2="24" y2="29" stroke={blue} stroke-width={SW + 0.4} />
			<path d="M17 29 h14 l-2 5 h-10 z" fill="#fff" stroke={blue} stroke-width={SW} stroke-linejoin="round" />
			<path d="M24 9 l0.9 2.6 l2.7 0 l-2.2 1.7 l0.8 2.6 l-2.2 -1.6 l-2.2 1.6 l0.8 -2.6 l-2.2 -1.7 l2.7 0 z" fill={green} />
		</svg>
	)}
</span>
