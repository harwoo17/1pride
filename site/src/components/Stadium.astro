---
// Stadium — a distinctive blueprint/HUD rendering of a football stadium,
// drawn in the brief's retro-future language: silver + retro-green wire
// lines on the Honolulu-blue field, mono FIG. annotations, a scanning
// sweep line, and a perspective playing surface with yard numbers and
// blue/silver end zones. Replaces the old faint silhouette.
---

<section class="stadium" aria-label="Stadium blueprint">
	<p class="stadium-kicker">FIG. 05 — THE STADIUM · 1:1000</p>
	<div class="stadium-frame">
		<svg viewBox="0 0 900 360" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Blueprint of a football stadium">
			<defs>
				<linearGradient id="fieldFade" x1="0" y1="0" x2="0" y2="1">
					<stop offset="0%" stop-color="#ffffff" stop-opacity="0.05" />
					<stop offset="100%" stop-color="#ffffff" stop-opacity="0.16" />
				</linearGradient>
				<radialGradient id="bowlGlow" cx="50%" cy="38%" r="70%">
					<stop offset="0%" stop-color="#34e27a" stop-opacity="0.16" />
					<stop offset="100%" stop-color="#34e27a" stop-opacity="0" />
				</radialGradient>
			</defs>

			<!-- glow -->
			<rect x="0" y="0" width="900" height="360" fill="url(#bowlGlow)" />

			<!-- OUTER BOWL — concentric silver tiers, perspective trapezoids -->
			<g stroke="#b0b7bc" fill="none" stroke-width="1.4" opacity="0.85">
				<path d="M70 300 L150 70 L750 70 L830 300 Z" />
				<path d="M120 300 L188 104 L712 104 L780 300 Z" />
				<path d="M172 300 L228 138 L672 138 L728 300 Z" />
			</g>

			<!-- press box ticks (upper rim) -->
			<g stroke="#34e27a" stroke-width="1.4" opacity="0.7">
				<line x1="150" y1="70" x2="150" y2="58" />
				<line x1="300" y1="70" x2="300" y2="58" />
				<line x1="450" y1="70" x2="450" y2="58" />
				<line x1="600" y1="70" x2="600" y2="58" />
				<line x1="750" y1="70" x2="750" y2="58" />
			</g>

			<!-- THE FIELD — perspective playing surface -->
			<polygon points="248,300 290,168 660,168 712,300" fill="url(#fieldFade)" stroke="#ffffff" stroke-width="1.6" />

			<!-- end zones (blue near, silver far) -->
			<polygon points="248,300 712,300 700,272 260,272" fill="#0076b6" stroke="#ffffff" stroke-width="1.2" opacity="0.55" />
			<polygon points="290,168 660,168 656,184 294,184" fill="#b0b7bc" stroke="#ffffff" stroke-width="1" opacity="0.4" />

			<!-- yard lines across the field (perspective spacing) -->
			<g stroke="#ffffff" stroke-width="1" opacity="0.5">
				<line x1="266" y1="272" x2="694" y2="272" />
				<line x1="278" y1="240" x2="682" y2="240" />
				<line x1="286" y1="214" x2="674" y2="214" />
				<line x1="292" y1="196" x2="668" y2="196" />
			</g>
			<!-- 50 / mid -->
			<line x1="296" y1="184" x2="664" y2="184" stroke="#34e27a" stroke-width="1.4" opacity="0.8" />

			<!-- midfield star -->
			<path d="M480 232 l4 8.5 l9.2 0.6 l-7 6 l2.3 9 l-8.5 -5 l-8.5 5 l2.3 -9 l-7 -6 l9.2 -0.6 z"
			      fill="none" stroke="#34e27a" stroke-width="1.3" opacity="0.85" transform="translate(-1,0)" />

			<!-- goal posts -->
			<g stroke="#ffffff" stroke-width="1.6" opacity="0.85">
				<line x1="480" y1="300" x2="480" y2="312" />
				<line x1="470" y1="312" x2="490" y2="312" />
				<line x1="473" y1="312" x2="473" y2="320" />
				<line x1="487" y1="312" x2="487" y2="320" />
			</g>

			<!-- dimension line -->
			<g stroke="#34e27a" stroke-width="1.2" opacity="0.8">
				<line x1="248" y1="332" x2="712" y2="332" />
				<line x1="248" y1="326" x2="248" y2="338" />
				<line x1="712" y1="326" x2="712" y2="338" />
			</g>
			<text x="480" y="350" text-anchor="middle" fill="#34e27a" font-family="monospace" font-size="11" letter-spacing="2">120 YDS</text>

			<!-- HUD corner labels -->
			<text x="70" y="44" fill="#b0b7bc" font-family="monospace" font-size="11" letter-spacing="2">SECT. 1PRIDE</text>
			<text x="830" y="44" text-anchor="end" fill="#b0b7bc" font-family="monospace" font-size="11" letter-spacing="2">CAP. 65,000</text>

			<!-- scanning sweep -->
			<line class="sweep" x1="0" y1="70" x2="0" y2="300" stroke="#34e27a" stroke-width="1.2" opacity="0.5" />
		</svg>
	</div>
</section>

<style>
	.stadium {
		margin: 2.5rem 0;
	}
	.stadium-kicker {
		font-family: var(--sl-font-mono, monospace);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		color: var(--silver-light, #d7dce0);
		margin: 0 0 0.75rem;
	}
	.stadium-frame {
		position: relative;
		border: 1px solid rgba(255, 255, 255, 0.25);
		border-radius: 10px;
		overflow: hidden;
		background:
			repeating-linear-gradient(90deg, rgba(52,226,122,0.10) 0 1px, transparent 1px 48px),
			repeating-linear-gradient(180deg, rgba(52,226,122,0.10) 0 1px, transparent 1px 48px);
	}
	.stadium-frame svg {
		display: block;
		width: 100%;
		height: auto;
	}
	.sweep {
		animation: stadium-sweep 6s linear infinite;
	}
	@keyframes stadium-sweep {
		0%   { transform: translateX(0); opacity: 0; }
		8%   { opacity: 0.5; }
		92%  { opacity: 0.5; }
		100% { transform: translateX(900px); opacity: 0; }
	}
	@media (prefers-reduced-motion: reduce) {
		.sweep { animation: none; opacity: 0; }
	}
</style>
