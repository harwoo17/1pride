---
// Decorative stadium silhouette — a two-tier bowl with goal posts and a
// field line, rendered as a single inline SVG in Honolulu blue. Used as
// a subtle visual beat between hero copy and the depth-chart section.
---

<div class="stadium-silhouette" aria-hidden="true">
	<svg viewBox="0 0 1200 130" xmlns="http://www.w3.org/2000/svg">
		<!-- Roof / press box -->
		<path
			d="M 220 56 L 220 42 L 980 42 L 980 56 Z"
			fill="var(--lions-blue)"
			opacity="0.10"
		/>
		<!-- Upper bowl -->
		<path
			d="M 140 64 Q 200 44 280 42 L 920 42 Q 1000 44 1060 64 L 1060 78 L 140 78 Z"
			fill="var(--lions-blue)"
			opacity="0.13"
		/>
		<!-- Lower bowl -->
		<path
			d="M 60 100 Q 120 78 220 76 L 980 76 Q 1080 78 1140 100 L 1140 116 L 60 116 Z"
			fill="var(--lions-blue)"
			opacity="0.18"
		/>
		<!-- Goal post left -->
		<line x1="170" y1="116" x2="170" y2="90" stroke="var(--lions-blue)" stroke-width="2.4" opacity="0.45" />
		<line x1="160" y1="90" x2="180" y2="90" stroke="var(--lions-blue)" stroke-width="2.4" opacity="0.45" />
		<line x1="166" y1="90" x2="166" y2="78" stroke="var(--lions-blue)" stroke-width="2" opacity="0.45" />
		<line x1="174" y1="90" x2="174" y2="78" stroke="var(--lions-blue)" stroke-width="2" opacity="0.45" />
		<!-- Goal post right -->
		<line x1="1030" y1="116" x2="1030" y2="90" stroke="var(--lions-blue)" stroke-width="2.4" opacity="0.45" />
		<line x1="1020" y1="90" x2="1040" y2="90" stroke="var(--lions-blue)" stroke-width="2.4" opacity="0.45" />
		<line x1="1026" y1="90" x2="1026" y2="78" stroke="var(--lions-blue)" stroke-width="2" opacity="0.45" />
		<line x1="1034" y1="90" x2="1034" y2="78" stroke="var(--lions-blue)" stroke-width="2" opacity="0.45" />
		<!-- Field line -->
		<line x1="60" y1="124" x2="1140" y2="124" stroke="var(--lions-blue)" stroke-width="1.5" opacity="0.4" />
		<!-- City marker text -->
		<text
			x="600"
			y="20"
			text-anchor="middle"
			font-family="var(--font-display, system-ui)"
			font-size="14"
			font-weight="900"
			letter-spacing="6"
			fill="var(--lions-blue)"
			opacity="0.55"
		>DETROIT · MOTOR CITY</text>
	</svg>
</div>
