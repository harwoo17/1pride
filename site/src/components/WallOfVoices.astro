---
// Wall of Voices (design brief §7). Renders only quotes that pass the
// no-fabrication filter in quotes.ts (each has a verifiable source_url).
// Style: large opening quote mark in silver, attribution in JetBrains
// Mono uppercase, source link on the attribution line.
import { getQuotes } from '~/data/quotes';
const quotes = getQuotes();
---

{quotes.length > 0 && (
	<section class="wall-of-voices" aria-label="Wall of Voices">
		<p class="wov-kicker">FIG. 06 — WALL OF VOICES</p>
		<div class="wov-grid">
			{quotes.map((q) => (
				<figure class="wov-card">
					<span class="wov-mark" aria-hidden="true">&ldquo;</span>
					<blockquote class="wov-text">{q.text}</blockquote>
					<figcaption class="wov-cite">
						<span class="wov-name">{q.name}</span>
						<span class="wov-role">{q.role} · {q.year}</span>
						<a class="wov-src" href={q.sourceUrl} target="_blank" rel="noopener" title={q.sourceLabel}>
							SOURCE ↗
						</a>
					</figcaption>
				</figure>
			))}
		</div>
	</section>
)}

<style>
	.wall-of-voices {
		margin: 2.5rem 0 1rem;
	}
	.wov-kicker {
		font-family: var(--sl-font-mono, monospace);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		color: var(--silver, #b0b7bc);
		margin: 0 0 1rem;
	}
	.wov-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}
	.wov-card {
		position: relative;
		margin: 0;
		padding: 1.25rem 1.25rem 1rem;
		background: var(--paper, #fff);
		border: 1px solid var(--silver, #b0b7bc);
		border-radius: 10px;
		overflow: hidden;
	}
	.wov-mark {
		position: absolute;
		top: -0.35rem;
		left: 0.5rem;
		font-family: var(--font-display, Georgia, serif);
		font-size: 4.5rem;
		line-height: 1;
		color: var(--silver, #b0b7bc);
		opacity: 0.45;
		pointer-events: none;
	}
	.wov-text {
		position: relative;
		margin: 0.5rem 0 1rem;
		padding: 0;
		border: 0;
		font-family: var(--sl-font, system-ui), sans-serif;
		font-size: 1.02rem;
		line-height: 1.45;
		color: var(--ink, #0b0b0c);
		font-style: normal;
	}
	.wov-cite {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.4rem 0.75rem;
		font-family: var(--sl-font-mono, monospace);
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		border-top: 1px solid var(--silver-light, #d7dce0);
		padding-top: 0.6rem;
	}
	.wov-name {
		color: var(--honolulu, #0076b6);
		font-weight: 700;
	}
	.wov-role {
		color: var(--ink, #0b0b0c);
		opacity: 0.7;
	}
	.wov-src {
		margin-left: auto;
		color: var(--honolulu, #0076b6);
		text-decoration: none;
	}
	.wov-src:hover {
		text-decoration: underline;
	}
</style>
