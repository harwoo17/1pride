---
// src/pages/lessons/[...slug].astro
//
// Renders one lesson on-brand: a Honolulu-blue page with a white reading
// panel, the tier's 3D avatar, The Film Room seeded with the lesson's
// starterQuery, the global sound system + mute toggle, and brand chrome.

import { getCollection, render } from 'astro:content';
import FilmRoom from '../../components/FilmRoom.tsx';
import Avatar from '../../components/Avatar.astro';
import { seasonWeekView } from '../../lib/season';
import { TIERS } from '../../data/tiers';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons
    .sort((a, b) => a.data.order - b.data.order)
    .map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, tier, kicker, section, dataset, starterQuery, vizSpec } = entry.data;

const tierIdx = TIERS.findIndex((t) => t.label === tier);
const tierNum = tierIdx >= 0 ? tierIdx + 1 : 1;

const name2026 = dataset.find((d: string) => d.endsWith('_2026'));
const extra = name2026 ? await seasonWeekView(name2026, '2026') : null;
const extraViews = extra ? [extra] : [];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — 1PRIDE</title>
    <meta name="description" content={`${title} — a 1PRIDE drill. Run real Lions SQL in The Film Room.`} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@125,400..900&family=Saira:wght@300..700&family=JetBrains+Mono:wght@400..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="lx-top">
      <a class="lx-brand" href="/">1PRIDE</a>
      <nav class="lx-nav">
        <a href="/depth-chart/">The Depth Chart</a>
        <a href="/">The Playbook</a>
      </nav>
    </header>

    <main class="lx">
      <div class="lx-panel">
        <div class="lx-head">
          <div class="lx-avatar"><Avatar tier={tierNum} size={108} /></div>
          <div>
            <p class="lx-kicker">{kicker} · {section} · TIER {String(tierNum).padStart(2, '0')} — {tier}</p>
            <h1>{title}</h1>
          </div>
        </div>

        <article class="prose">
          <Content />
        </article>

        <div class="lx-filmroom">
          <p class="lx-kicker lx-fr-kicker">▶ RUN THIS IN THE FILM ROOM</p>
          <FilmRoom
            client:only="react"
            initialQuery={starterQuery}
            datasets={dataset}
            vizSpec={vizSpec}
            extraViews={extraViews}
          />
        </div>

        <footer class="lx-foot">
          <a class="lx-back" href="/depth-chart/">← Back to The Depth Chart</a>
          <span class="lx-foot-note">Every rep is a read.</span>
        </footer>
      </div>
    </main>

    <style>
      :root {
        --honolulu: #0076b6;
        --honolulu-700: #00659c;
        --silver: #b0b7bc;
        --silver-light: #d7dce0;
        --ink: #0b0b0c;
        --paper: #ffffff;
        --retro-green: #34e27a;
      }
      html, body { margin: 0; }
      body {
        background: var(--honolulu);
        color: #fff;
        font-family: 'Saira', system-ui, sans-serif;
        min-height: 100vh;
      }
      /* header */
      .lx-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px clamp(16px, 5vw, 48px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.22);
      }
      .lx-brand {
        font-family: 'Archivo', sans-serif;
        font-weight: 800;
        font-size: 1.4rem;
        letter-spacing: -0.01em;
        color: #fff;
        text-decoration: none;
      }
      .lx-nav { display: flex; gap: 1.25rem; }
      .lx-nav a {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--silver-light);
        text-decoration: none;
      }
      .lx-nav a:hover { color: #fff; }
      /* panel */
      .lx { padding: clamp(20px, 5vw, 56px) clamp(16px, 5vw, 48px) 96px; }
      .lx-panel {
        max-width: 880px;
        margin: 0 auto;
        background: var(--paper);
        color: var(--ink);
        border: 1px solid var(--silver);
        border-radius: 14px;
        padding: clamp(24px, 4vw, 48px);
      }
      .lx-head {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-bottom: 1.5rem;
      }
      .lx-avatar { flex-shrink: 0; }
      .lx-kicker {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        color: var(--honolulu);
        text-transform: uppercase;
        margin: 0 0 0.5rem;
      }
      h1 {
        font-family: 'Archivo', 'Saira', sans-serif;
        font-weight: 800;
        letter-spacing: -0.02em;
        font-size: clamp(30px, 5vw, 52px);
        line-height: 1.02;
        margin: 0;
        color: var(--ink);
      }
      .prose { color: var(--ink); }
      .prose :is(h2, h3) {
        font-family: 'Archivo', 'Saira', sans-serif;
        font-weight: 800;
        letter-spacing: -0.01em;
        margin-top: 2.25rem;
      }
      .prose p, .prose li { line-height: 1.65; color: var(--ink); }
      .prose hr { border: 0; border-top: 1px solid var(--silver-light); margin: 2rem 0; }
      .prose :not(pre) > code {
        background: var(--silver-light);
        color: var(--honolulu-700);
        padding: 0.1em 0.35em;
        border-radius: 3px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.9em;
      }
      .prose pre {
        background: var(--ink);              /* Lions black — NOT navy */
        color: #eef1f3;
        padding: 16px 18px;
        border-radius: 8px;
        border-left: 3px solid var(--retro-green);
        overflow-x: auto;
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        line-height: 1.5;
      }
      .prose pre code { background: transparent; color: inherit; padding: 0; }
      .prose blockquote {
        border-left: 3px solid var(--honolulu);
        margin: 1.5rem 0;
        padding: 0.25rem 0 0.25rem 1rem;
        color: #3a3d40;
        font-style: italic;
      }
      /* film room */
      .lx-filmroom {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--silver);
      }
      .lx-fr-kicker { color: var(--retro-green); font-weight: 700; }
      /* footer */
      .lx-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 2.25rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--silver-light);
      }
      .lx-back {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        color: var(--honolulu);
        text-decoration: none;
      }
      .lx-back:hover { text-decoration: underline; }
      .lx-foot-note {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--silver-dark, #6a7178);
      }
    </style>

    <!-- Sound system + mute toggle (mirrors the Starlight head script) -->
    <script is:inline>
      (function () {
        var KEY = 'pride-muted';
        var actx = null;
        function muted() { return localStorage.getItem(KEY) === '1'; }
        function ctx() {
          if (!actx && (window.AudioContext || window.webkitAudioContext))
            actx = new (window.AudioContext || window.webkitAudioContext)();
          if (actx && actx.state === 'suspended') actx.resume();
          return actx;
        }
        function snap() {
          if (muted()) return;
          var x = ctx(); if (!x) return;
          var t = x.currentTime, o = x.createOscillator(), g = x.createGain();
          o.type = 'square';
          o.frequency.setValueAtTime(220, t);
          o.frequency.exponentialRampToValueAtTime(90, t + 0.04);
          g.gain.setValueAtTime(0.0001, t);
          g.gain.exponentialRampToValueAtTime(0.13, t + 0.004);
          g.gain.exponentialRampToValueAtTime(0.0001, t + 0.07);
          o.connect(g).connect(x.destination);
          o.start(t); o.stop(t + 0.08);
        }
        document.addEventListener('click', function (e) {
          var t = e.target;
          if (!t.closest || t.closest('#prideMute')) return;
          if (t.closest('button, a[href]')) snap();
        });
        function mount() {
          if (document.getElementById('prideMute')) return;
          var b = document.createElement('button');
          b.id = 'prideMute'; b.type = 'button';
          b.setAttribute('aria-label', 'Toggle sound');
          b.style.cssText = 'position:fixed;right:16px;bottom:16px;z-index:9999;width:40px;height:40px;border-radius:999px;border:1px solid #B0B7BC;background:#0076B6;color:#fff;font-size:15px;cursor:pointer;box-shadow:0 4px 14px rgba(0,0,0,.25);display:flex;align-items:center;justify-content:center;';
          function paint() { b.textContent = muted() ? '🔇' : '🔊'; }
          paint();
          b.addEventListener('click', function () {
            localStorage.setItem(KEY, muted() ? '0' : '1'); paint(); if (!muted()) snap();
          });
          document.body.appendChild(b);
        }
        if (document.body) mount(); else document.addEventListener('DOMContentLoaded', mount);
      })();
    </script>
  </body>
</html>
